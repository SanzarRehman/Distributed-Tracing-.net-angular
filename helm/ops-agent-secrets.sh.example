#!/usr/bin/env bash
# Copy this file to helm/ops-agent-secrets.sh and fill in real values.
# The real helm/ops-agent-secrets.sh file is gitignored and is sourced by aws-deploy.sh.

# Option A: OpenAI
# OPENAI_API_KEY="sk-..."

# Option B: Azure OpenAI

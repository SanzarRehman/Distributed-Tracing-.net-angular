# =============================================================
# Pathfinder - Environment Variables
# =============================================================
# Copy this file to .env and fill in your values.
# Then run: docker compose up -d
# =============================================================

# ─── Port Bindings (Optional) ────────────────────────────────
# You can override default ports by uncommenting the lines below
# API_PORT=5215
# UI_PORT=4200
# JAEGER_PORT=16686
# OTEL_COLLECTOR_GRPC_PORT=4319
# OTEL_COLLECTOR_HTTP_PORT=4320
# NEWAPP_PORT=8080
# RABBITMQ_AMQP_PORT=5672
# RABBITMQ_UI_PORT=15672

# ─── Angular UI ──────────────────────────────────────────────
# Public URL of the backend API (must be reachable from the browser)
API_URL=http://localhost:5215/api

# Public URL of the OTel Collector HTTP endpoint (must be reachable from the browser)
# Browser → Collector → Jaeger + Custom App
OTEL_COLLECTOR_HTTP_URL=http://localhost:4320/v1/traces

# ─── .NET API ────────────────────────────────────────────────
# Name displayed in Jaeger / traces
DOTNET_SERVICE_NAME=pathfinder-api

# ─── OTel Collector ──────────────────────────────────────────
# Where the collector PUSHES full traces to your custom application (gRPC OTLP).
# Your custom app must listen on this address with an OTLP gRPC receiver.
#
#  • Custom app on the same host:   host.docker.internal:4317
#  • Custom app on another server:  192.168.1.50:4317
#  • Custom app in same compose:    your-service-name:4317
CUSTOM_CONSUMER_ENDPOINT=host.docker.internal:4317

# ─── CORS origins for OTel Collector HTTP receiver ───────────
# Comma-separated list is NOT supported here — update otel-collector-config.yaml
# if you need to add extra origins beyond localhost:4200 / 4201.

# ─── Inter-service Connections (Override for AWS) ────────────
# On AWS ECS, replace these with Cloud Map / ALB endpoints.
# Locally (docker-compose), the defaults work out of the box.
#
# RABBITMQ_HOST=rabbitmq
# NEWAPP_URL=http://newapp:8080/api/newapp/process
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
# CORS_ORIGINS=http://localhost:4200,http://localhost:4201
# JAEGER_URL=http://localhost:16686
